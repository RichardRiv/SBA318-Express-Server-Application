<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Games</title>
        <link rel="stylesheet" href="/styles.css">
	</head>
	<body>
		<h1>Games</h1>

        <div>
            <a href="/home/game/add">
                <button>Add Game</button>
            </a>
            <form action="/home" method="get" style="display: inline;">
                <select name="genre" onchange="this.form.submit()">
                    <option value="">All genres</option>
                    <% genres.forEach(g => { %>
                    <option value="<%= g %>" <%= selectedGenre === g ? 'selected' : '' %>><%= g %></option>
                    <% }) %>
                </select>
            </form>
        </div>
		<table>
			<thead>
				<tr>
					<th>Title</th>
					<th>Developer</th>
					<th>Genre</th>
					<th>Rating</th>
					<th>Actions</th>
				</tr>
			</thead>
			<tbody>
                <% gamesData.forEach((game) => { %>
                    <tr>
                        <td><a href="/home/game/<%= game.id %>"><%= game.title %></a></td>
                        <td><%= game.developer.name %></td>
                        <td><%= game.genre %></td>
                        <td><%= game.rating %></td>
                        <td>
                            <form method="get" action="/home/game/<%= game.id %>/edit">
                                <button type="submit">Edit</button>
                            </form>
                        </td>
                        <td>
                            <form method="post" action="/home/game/<%= game.id %>?_method=DELETE">
                                <button type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
		</table>
	</body>
</html>
