<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Games</title>
	</head>
	<body>
		<h1>Games</h1>

		<table>
			<thead>
				<tr>
					<th>Title</th>
					<th>Developer</th>
					<th>Genre</th>
					<th>Rating</th>
					<th>Actions</th>
				</tr>
			</thead>
			<tbody>
                <% gameData.forEach((game) => { %>
                    <tr>
                        <td><a href="/game/<%= game.id %>"><%= game.title %></a></td>
                        <td><%= game.developer.name %></td>
                        <td><%= game.genre %></td>
                        <td><%= game.rating %></td>
                        <td>
                            <form method="get" action="/game/<%= game.id %>/edit">
                                <button type="submit">Edit</button>
                            </form>
                        </td>
                        <td>
                            <form method="post" action="/game/<%= game.id %>?_method=DELETE">
                                <button type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
		</table>
	</body>
</html>
